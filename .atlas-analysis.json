  "keyFeatures": [
    "OpenTelemetry-native auto-instrumentation for 50+ LLM providers, AI frameworks, and vector databases",
    "Real-time GPU monitoring for NVIDIA and AMD GPUs",
    "LLM-as-a-judge and programmatic evaluations for AI response quality",
    "Prompt Hub for versioning and managing prompts across environments",
    "Vault for centralized LLM API key and secrets management",
    "OpenGround playground for comparing LLMs side-by-side",
    "Custom dashboards with flexible widgets and SQL queries over telemetry data",
    "Fleet Hub for OpAMP-based management of OpenTelemetry Collectors",
    "Cost tracking for both standard and custom/fine-tuned models",
    "Kubernetes operator for zero-code instrumentation injection"
  ],
  "publicApiSurface": [
    "openlit.init(environment, application_name, otlp_endpoint, otlp_headers, collect_gpu_stats, disable_metrics, pricing_json, ...)",
    "openlit.evals — programmatic evaluation functions (hallucination, bias, toxicity, etc.)",
    "openlit.guard — real-time guardrail checks for prompt injection, topic restrictions, sensitive data",
    "GET /api/prompt — retrieve prompts from Prompt Hub",
    "GET /api/vault — retrieve secrets from Vault",
    "GPUInstrumentor — standalone GPU metrics collector",
    "TypeScript SDK: OpenLIT.init() with same configuration options",
    "Go SDK: openlit instrumentation for OpenAI and Anthropic"
  ]
}
